# Environment configuration for AI-native development framework
# Copy this file to .env and fill in your actual values

# LLM Provider API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
KIMI_API_KEY=your_kimi_api_key_here

# Kimi Configuration
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_DEFAULT_MODEL=kimi-k2-6-latest

# LangGraph / LangChain
LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=ai-native-framework

# Helicone
HELICONE_API_KEY=your_helicone_api_key_here

# Vector Database
# Choose one: pinecone, weaviate, chroma
VECTOR_DB_PROVIDER=chroma
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=your_pinecone_environment
WEAVIATE_URL=your_weaviate_url
WEAVIATE_API_KEY=your_weaviate_api_key
CHROMA_PERSIST_DIR=./data/chroma

# Cloud Provider (choose one)
CLOUD_PROVIDER=local
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
GCP_PROJECT_ID=your_gcp_project
AZURE_SUBSCRIPTION_ID=your_azure_subscription

# GitHub
GITHUB_TOKEN=your_github_token
GITHUB_ORG=your_org

# Security Tools
SNYK_TOKEN=your_snyk_token

# Framework Settings
DEFAULT_PROVIDER_STRATEGY=hybrid
SPRINT_BUDGET_USD=100
COST_ALERT_THRESHOLDS=0.5,0.75,0.9,1.0
MIN_TEST_COVERAGE=80
MAX_RETRY_ATTEMPTS=3
ESCALATION_TIMEOUT_MINUTES=30

# Monitoring
LOG_LEVEL=INFO
AGENT_STATE_CHECKPOINT_INTERVAL_SECONDS=30
